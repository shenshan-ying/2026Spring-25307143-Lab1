#!/bin/bash
# HarmonyOS Hvigor Wrapper Script

DEFAULT_HVIGOR_VERSION="4.0.2"
HVIGOR_VERSION="${HVIGOR_VERSION:-$DEFAULT_HVIGOR_VERSION}"
HVIGOR_APP_HOME=$(dirname $(readlink -f "$0" 2>/dev/null || echo "$0"))
HVIGOR_WRAPPER_DIR="$HVIGOR_APP_HOME/.hvigor"
HVIGOR_WRAPPER_JAR="$HVIGOR_WRAPPER_DIR/hvigor-wrapper.jar"

# Download hvigor-wrapper.jar if not exists
if [ ! -f "$HVIGOR_WRAPPER_JAR" ]; then
    echo "Hvigor wrapper JAR not found. Please sync project in DevEco Studio first."
    exit 1
fi

exec node "$HVIGOR_WRAPPER_DIR/hvigor.js" "$@"
